# ===========================================
# Yerel geliştirme (Backend + Mobile ayrı çalıştırma)
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# ===========================================

# --- Veritabanı (Backend için zorunlu) ---
DATABASE_URL="postgresql://postgres:123456@localhost:5432/BabySteps"
# Örnek (şifresiz): postgresql://plaiteknoloji@localhost:5432/postgres
# Şifre varsa: postgresql://postgres:sifre@localhost:5432/postgres

# --- Backend (API sunucusu) ---
# Port (varsayılan: 3000)
PORT=3000
# JWT / oturum için (isteğe bağlı; yoksa uygulama yine çalışır)
# JWT_SECRET="gizli-bir-anahtar"

# --- Mobile/Web istemcisinin backend adresi ---
# Yerel API (npm run dev:server, PORT=3000).
# Aynı Wi‑Fi: PC’nin Wi‑Fi IPv4’ü (ipconfig → "Wireless LAN adapter Wi-Fi"). USB+reverse ise http://127.0.0.1:3000
# Sadece bu makinede web: http://localhost:3000
# Production: https://babysteps-production-9e72.up.railway.app
EXPO_PUBLIC_API_BASE_URL="http://10.61.12.20:3000"

# --- OAuth (Manus vb. – isteğe bağlı) ---
# EXPO_PUBLIC_OAUTH_PORTAL_URL=""
# EXPO_PUBLIC_OAUTH_SERVER_URL=""
# EXPO_PUBLIC_APP_ID=""
# VITE_APP_ID=""

# --- Diğer (isteğe bağlı) ---
# BUILT_IN_FORGE_API_URL=""
# BUILT_IN_FORGE_API_KEY=""
# OPENAI_API_KEY=""
